@page "/module-leader/dashboard"
@model BlindMatch.Web.Pages.ModuleLeader.DashboardModel
@using BlindMatch.Core.Common
@{
    ViewData["Title"] = "Module Leader — Dashboard";
}

<div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
        <h1>Dashboard</h1>
        <p>Overview of proposals, matches, and recent activity</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/module-leader/matches" class="btn btn-primary btn-sm">Review Matches</a>
        <a href="/module-leader/proposals" class="btn btn-outline-secondary btn-sm">All Proposals</a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-lg-4">
        <div class="card stat-card">
            <div class="card-body">
                <div class="stat-number">@Model.ViewModel.TotalProposals</div>
                <div class="stat-label">Total Proposals</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-4">
        <div class="card stat-card">
            <div class="card-body">
                <div class="stat-number" style="color:#d4aa5a">@Model.ViewModel.PendingMatches</div>
                <div class="stat-label">Pending Matches</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-4">
        <div class="card stat-card">
            <div class="card-body">
                <div class="stat-number" style="color:#6aaa7a">@Model.ViewModel.ActiveMatches</div>
                <div class="stat-label">Approved Matches</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">Proposals by Status</div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Status</th>
                            <th class="text-end">Count</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kv in Model.ViewModel.ProposalsByStatus)
                        {
                            <tr>
                                <td>
                                    @{
                                        var bs = kv.Key.ToString() switch {
                                            "Submitted" => "background:rgba(200,164,90,.12);color:#c8a45a;border:1px solid rgba(200,164,90,.25)",
                                            "Matched"   => "background:rgba(74,124,89,.15);color:#6aaa7a;border:1px solid rgba(74,124,89,.25)",
                                            "Pending"   => "background:rgba(180,140,40,.15);color:#d4aa5a;border:1px solid rgba(180,140,40,.25)",
                                            "Rejected"  => "background:rgba(122,48,48,.15);color:#e07878;border:1px solid rgba(122,48,48,.25)",
                                            "Withdrawn" => "background:rgba(80,70,60,.2);color:#8a7d6a;border:1px solid rgba(80,70,60,.3)",
                                            _           => "background:var(--surface-3);color:var(--text-muted);border:1px solid var(--border-light)"
                                        };
                                    }
                                    <span class="badge" style="@bs;font-size:.65rem;letter-spacing:.06em">@kv.Key</span>
                                </td>
                                <td class="text-end fw-semibold">@kv.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header">Recent Activity</div>
            @if (Model.ViewModel.RecentActivity.Any())
            {
                <div class="card-body p-0">
                    <table class="table table-sm table-hover mb-0">
                        <thead>
                            <tr>
                                <th>When</th>
                                <th>Who</th>
                                <th>Action</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ev in Model.ViewModel.RecentActivity)
                            {
                                <tr>
                                    <td class="text-muted">@ev.When.ToLocalTime().ToString("d MMM, HH:mm")</td>
                                    <td>@ev.Who</td>
                                    <td><span class="badge" style="background:rgba(200,164,90,.12);color:#c8a45a;border:1px solid rgba(200,164,90,.2);font-size:.65rem;letter-spacing:.05em">@ev.Action</span></td>
                                    <td class="text-muted">@ev.Details</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="card-body">
                    <p class="text-muted mb-0">No recent activity to display.</p>
                </div>
            }
        </div>
    </div>
</div>
