@page "/module-leader/proposal-oversight"
@model BlindMatch.Web.Pages.ModuleLeader.ProposalOversightModel
@using BlindMatch.Core.Enums
@{
    ViewData["Title"] = "Proposal Oversight";
    var count = Model.Proposals.Count;
}

<div class="page-header d-flex align-items-end justify-content-between flex-wrap gap-2">
    <div>
        <h1>Proposal Oversight</h1>
        <p>@count proposal@(count == 1 ? "" : "s") in the system</p>
    </div>
    <div class="d-flex gap-2 mb-1 flex-wrap">
        <a class="btn btn-sm @(Model.FilterStatus == null ? "btn-primary" : "btn-outline-secondary")"
           asp-page="" asp-route-filterStatus="">All</a>
        <a class="btn btn-sm @(Model.FilterStatus == ProposalStatus.Submitted ? "btn-primary" : "btn-outline-secondary")"
           asp-page="" asp-route-filterStatus="@ProposalStatus.Submitted">Submitted</a>
        <a class="btn btn-sm @(Model.FilterStatus == ProposalStatus.Matched ? "btn-primary" : "btn-outline-secondary")"
           asp-page="" asp-route-filterStatus="@ProposalStatus.Matched">Matched</a>
        <a class="btn btn-sm @(Model.FilterStatus == ProposalStatus.Rejected ? "btn-primary" : "btn-outline-secondary")"
           asp-page="" asp-route-filterStatus="@ProposalStatus.Rejected">Rejected</a>
        <a class="btn btn-sm @(Model.FilterStatus == ProposalStatus.Withdrawn ? "btn-primary" : "btn-outline-secondary")"
           asp-page="" asp-route-filterStatus="@ProposalStatus.Withdrawn">Withdrawn</a>
    </div>
</div>

@if (!Model.Proposals.Any())
{
    <div class="card" style="max-width:480px">
        <div class="card-body p-4 text-center">
            <p style="color:var(--text-muted);margin:0;font-size:.875rem">No proposals match the selected filter.</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Project</th>
                        <th>Title</th>
                        <th>Student</th>
                        <th>Area</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th>Change Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Proposals)
                    {
                        <tr>
                            <td style="white-space:nowrap;font-size:.78rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--text-muted)">@p.ProjectCode</td>
                            <td style="max-width:260px">
                                <span style="display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:.875rem">@p.Title</span>
                            </td>
                            <td style="white-space:nowrap">
                                <div style="font-size:.85rem;color:var(--text)">@p.StudentName</div>
                                <div style="font-size:.78rem;color:var(--text-muted)">@p.StudentEmail</div>
                            </td>
                            <td>
                                <span class="badge browse-area-badge">@p.ResearchArea</span>
                            </td>
                            <td>
                                @{
                                    var bs = p.Status.ToString() switch {
                                        "Submitted"   => "background:rgba(200,164,90,.12);color:#c8a45a;border:1px solid rgba(200,164,90,.25)",
                                        "Matched"     => "background:rgba(74,124,89,.15);color:#6aaa7a;border:1px solid rgba(74,124,89,.25)",
                                        "UnderReview" => "background:rgba(180,140,40,.15);color:#d4aa5a;border:1px solid rgba(180,140,40,.25)",
                                        "Rejected"    => "background:rgba(122,48,48,.15);color:#e07878;border:1px solid rgba(122,48,48,.25)",
                                        "Withdrawn"   => "background:rgba(80,70,60,.2);color:#8a7d6a;border:1px solid rgba(80,70,60,.3)",
                                        _             => "background:var(--surface-3);color:var(--text-muted);border:1px solid var(--border-light)"
                                    };
                                }
                                <span class="badge" style="@bs;font-size:.65rem;letter-spacing:.06em">@p.Status</span>
                            </td>
                            <td style="white-space:nowrap;font-size:.82rem;color:var(--text-muted)">
                                @(p.SubmittedAt?.ToLocalTime().ToString("d MMM yyyy") ?? "—")
                            </td>
                            <td>
                                <form method="post" asp-page-handler="ChangeStatus" class="d-flex gap-2">
                                    <input type="hidden" name="proposalId" value="@p.Id" />
                                    <input type="hidden" name="newStatus" id="status-input-@p.Id" />
                                    <div class="dropdown">
                                        <button type="button"
                                                id="status-btn-@p.Id"
                                                class="form-control form-control-sm d-flex align-items-center justify-content-between gap-2 status-dropdown-toggle"
                                                style="min-width:140px;cursor:pointer"
                                                data-proposal="@p.Id">
                                            <span id="status-label-@p.Id" style="color:var(--text-subtle)">Change to…</span>
                                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;opacity:.5"><polyline points="6 9 12 15 18 9"/></svg>
                                        </button>
                                        <ul class="dropdown-menu" style="background:var(--surface-2);border-color:var(--border-light);padding:.35rem">
                                            <li><a class="dropdown-item status-option" href="#" data-proposal="@p.Id" data-value="@ProposalStatus.Draft" style="font-size:.82rem;border-radius:.35rem;color:var(--text-muted);padding:.45rem .75rem">Draft</a></li>
                                            <li><a class="dropdown-item status-option" href="#" data-proposal="@p.Id" data-value="@ProposalStatus.Submitted" style="font-size:.82rem;border-radius:.35rem;color:var(--text-muted);padding:.45rem .75rem">Submitted</a></li>
                                            <li><a class="dropdown-item status-option" href="#" data-proposal="@p.Id" data-value="@ProposalStatus.UnderReview" style="font-size:.82rem;border-radius:.35rem;color:var(--text-muted);padding:.45rem .75rem">Under Review</a></li>
                                            <li><a class="dropdown-item status-option" href="#" data-proposal="@p.Id" data-value="@ProposalStatus.Matched" style="font-size:.82rem;border-radius:.35rem;color:var(--text-muted);padding:.45rem .75rem">Matched</a></li>
                                            <li><a class="dropdown-item status-option" href="#" data-proposal="@p.Id" data-value="@ProposalStatus.Rejected" style="font-size:.82rem;border-radius:.35rem;color:var(--text-muted);padding:.45rem .75rem">Rejected</a></li>
                                            <li><a class="dropdown-item status-option" href="#" data-proposal="@p.Id" data-value="@ProposalStatus.Withdrawn" style="font-size:.82rem;border-radius:.35rem;color:var(--text-muted);padding:.45rem .75rem">Withdrawn</a></li>
                                        </ul>
                                    </div>
                                    <button type="submit" class="btn btn-outline-secondary btn-sm">Apply</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<script>
(function () {
    var openMenu = null, openTrigger = null, openContainer = null;

    function closeStatusMenu() {
        if (!openMenu) return;
        openMenu.classList.remove('show');
        openMenu.style.cssText = '';
        openContainer.appendChild(openMenu);
        openMenu = openTrigger = openContainer = null;
    }

    document.querySelectorAll('.status-dropdown-toggle').forEach(function (btn) {
        var container = btn.parentElement;
        var menu = container.querySelector('.dropdown-menu');

        btn.addEventListener('click', function (e) {
            e.preventDefault();
            e.stopPropagation();
            if (openMenu === menu) { closeStatusMenu(); return; }
            if (openMenu) closeStatusMenu();

            document.body.appendChild(menu);
            menu.classList.add('show');

            var rect = btn.getBoundingClientRect();
            var mh   = menu.offsetHeight;
            var top  = (window.innerHeight - rect.bottom > mh + 4)
                     ? rect.bottom + 2
                     : rect.top - mh - 2;

            menu.style.cssText = 'position:fixed;z-index:9999;left:' +
                Math.round(rect.left) + 'px;top:' + Math.round(top) +
                'px;min-width:' + Math.round(rect.width) + 'px';

            openMenu      = menu;
            openTrigger   = btn;
            openContainer = container;
        });
    });

    document.querySelectorAll('.status-option').forEach(function (item) {
        item.addEventListener('click', function (e) {
            e.preventDefault();
            var pid = this.dataset.proposal;
            document.getElementById('status-input-' + pid).value = this.dataset.value;
            var label = document.getElementById('status-label-' + pid);
            label.textContent = this.textContent.trim();
            label.style.color = 'var(--text)';
            this.closest('ul').querySelectorAll('.status-option').forEach(function (o) {
                o.style.color = 'var(--text-muted)';
            });
            this.style.color = 'var(--accent)';
            closeStatusMenu();
        });
    });

    document.addEventListener('click', function (e) {
        if (openMenu && !openMenu.contains(e.target) && e.target !== openTrigger)
            closeStatusMenu();
    });
})();
</script>
