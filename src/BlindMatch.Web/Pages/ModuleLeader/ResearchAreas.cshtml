@page "/module-leader/research-areas"
@model BlindMatch.Web.Pages.ModuleLeader.ResearchAreasModel
@{
    ViewData["Title"] = "Research Areas";
    var count = Model.ResearchAreas.Count;
    var activeCount = Model.ResearchAreas.Count(r => r.IsActive);
}

<div class="page-header d-flex align-items-end justify-content-between flex-wrap gap-2">
    <div>
        <h1>Research Areas</h1>
        <p>@activeCount active of @count total area@(count == 1 ? "" : "s")</p>
    </div>
    <a href="/module-leader/dashboard" class="btn btn-outline-secondary mb-1">Back to Dashboard</a>
</div>

<div class="card mb-4">
    <div class="card-header">Add New Research Area</div>
    <div class="card-body p-4">
        <form method="post" asp-page-handler="Create" class="d-flex gap-3">
            <div class="flex-fill">
                <input asp-for="NewArea.Name" class="form-control" placeholder="Research area name" required />
                <span asp-validation-for="NewArea.Name" style="font-size:.75rem;color:#e07878"></span>
            </div>
            <button type="submit" class="btn btn-primary flex-shrink-0">Add Area</button>
        </form>
    </div>
</div>

@if (!Model.ResearchAreas.Any())
{
    <div class="card" style="max-width:480px">
        <div class="card-body p-4 text-center">
            <p style="color:var(--text-muted);margin:0;font-size:.875rem">No research areas yet. Add one above.</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th style="width:1%;white-space:nowrap">Status</th>
                        <th style="width:1%;white-space:nowrap">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ra in Model.ResearchAreas)
                    {
                        <tr>
                            <td style="font-size:.875rem;font-weight:500;color:var(--text)">@ra.Name</td>
                            <td>
                                @if (ra.IsActive)
                                {
                                    <span class="badge" style="background:rgba(74,124,89,.15);color:#6aaa7a;border:1px solid rgba(74,124,89,.25);font-size:.65rem;letter-spacing:.06em">Active</span>
                                }
                                else
                                {
                                    <span class="badge" style="background:rgba(80,70,60,.2);color:#8a7d6a;border:1px solid rgba(80,70,60,.3);font-size:.65rem;letter-spacing:.06em">Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <button type="button"
                                            class="btn btn-outline-secondary btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editModal-@ra.Id">
                                        Edit
                                    </button>

                                    @if (ra.IsActive)
                                    {
                                        <form method="post" asp-page-handler="Deactivate" asp-route-id="@ra.Id">
                                            <button type="submit" class="btn btn-sm"
                                                    style="background:rgba(122,48,48,.2);color:#e07878;border:1px solid rgba(122,48,48,.35)">
                                                Deactivate
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Reactivate" asp-route-id="@ra.Id">
                                            <button type="submit" class="btn btn-sm"
                                                    style="background:rgba(200,164,90,.12);color:#c8a45a;border:1px solid rgba(200,164,90,.3)">
                                                Reactivate
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>

                        <div class="modal fade" id="editModal-@ra.Id" tabindex="-1">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                    <form method="post" asp-page-handler="Rename" asp-route-id="@ra.Id">
                                        <div class="modal-header">
                                            <h5 class="modal-title" style="font-size:.9rem;font-weight:600">Rename Research Area</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <label style="font-size:.75rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-muted);margin-bottom:.5rem;display:block">Name</label>
                                            <input type="text" name="newName" class="form-control" value="@ra.Name" required />
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-primary btn-sm">Save</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
