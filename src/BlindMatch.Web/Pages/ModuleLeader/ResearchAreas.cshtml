@page "/module-leader/research-areas"
@model BlindMatch.Web.Pages.ModuleLeader.ResearchAreasModel
@{
    ViewData["Title"] = "Research Areas";
}

<h1 class="mb-4">Research Area Management</h1>

<div class="card mb-4">
    <div class="card-header bg-light">
        <h5>Add New Research Area</h5>
    </div>
    <div class="card-body">
        <form method="post" asp-page-handler="Create" class="row g-2">
            <div class="col-sm-6">
                <input asp-for="NewArea.Name" class="form-control" placeholder="Research area name" required />
                <span asp-validation-for="NewArea.Name" class="text-danger small"></span>
            </div>
            <div class="col-sm-6">
                <button type="submit" class="btn btn-primary w-100">Create</button>
            </div>
        </form>
    </div>
</div>

<h4 class="mb-3">Existing Research Areas</h4>
<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ra in Model.ResearchAreas)
            {
                <tr>
                    <td>@ra.Name</td>
                    <td>
                        <span class="badge @(ra.IsActive ? "bg-success" : "bg-secondary")">
                            @(ra.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editModal-@ra.Id">Edit</button>

                        @if (ra.IsActive)
                        {
                            <form method="post" asp-page-handler="Deactivate" asp-route-id="@ra.Id" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-danger">Deactivate</button>
                            </form>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="Reactivate" asp-route-id="@ra.Id" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-warning">Reactivate</button>
                            </form>
                        }
                    </td>
                </tr>

                <div class="modal fade" id="editModal-@ra.Id" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form method="post" asp-page-handler="Rename" asp-route-id="@ra.Id">
                                <div class="modal-header">
                                    <h5 class="modal-title">Edit: @ra.Name</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <input type="text" name="newName" class="form-control" value="@ra.Name" required />
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary">Save</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </tbody>
    </table>
</div>