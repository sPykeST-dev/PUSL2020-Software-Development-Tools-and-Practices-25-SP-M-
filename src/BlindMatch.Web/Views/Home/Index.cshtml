@{
    ViewData["Title"] = "BlindMatch — Project Allocation System";
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<div class="hero text-center">
    <div class="container">
        <h1>Blind Project Allocation</h1>
        <p class="mt-3 mb-4">
            A fair, anonymised matching system connecting students and supervisors
            for research projects at NSBM Green University.
        </p>
        @if (!isAuthenticated)
        {
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a asp-controller="Account" asp-action="Login" class="btn btn-light px-4">Sign in</a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light px-4">Register as Student</a>
            </div>
        }
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card feature-card h-100">
            <div class="card-body p-4">
                <div class="feature-icon" style="background:rgba(90,130,200,.12);color:#7aaae8">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <line x1="10" y1="9" x2="8" y2="9"/>
                    </svg>
                </div>
                <h5 class="fw-semibold mb-2">Submit Your Proposal</h5>
                <p class="text-muted mb-0" style="font-size:.9rem">
                    Students submit a project proposal with title, abstract, technical stack, and keywords.
                    Your identity is hidden from supervisors until a match is confirmed.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card feature-card h-100">
            <div class="card-body p-4">
                <div class="feature-icon" style="background:rgba(200,164,90,.12);color:#c8a45a">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                        <line x1="1" y1="1" x2="23" y2="23"/>
                    </svg>
                </div>
                <h5 class="fw-semibold mb-2">Anonymous Browsing</h5>
                <p class="text-muted mb-0" style="font-size:.9rem">
                    Supervisors browse proposals without seeing student names, ensuring
                    selections are based purely on project merit and research alignment.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card feature-card h-100">
            <div class="card-body p-4">
                <div class="feature-icon" style="background:rgba(74,124,89,.14);color:#6aaa7a">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                </div>
                <h5 class="fw-semibold mb-2">Confirmed Match</h5>
                <p class="text-muted mb-0" style="font-size:.9rem">
                    Once a supervisor confirms interest, both parties' identities are revealed
                    and the match goes to the Module Leader for final approval.
                </p>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-4">
        <h5 class="fw-semibold mb-3">How it works</h5>
        <div class="row g-3">
            <div class="col-sm-6 col-lg-3">
                <div class="d-flex gap-3 align-items-start">
                    <span class="badge bg-primary rounded-circle p-2" style="font-size:.85rem;min-width:2rem;height:2rem;display:flex;align-items:center;justify-content:center;flex-shrink:0">1</span>
                    <div>
                        <div class="fw-semibold" style="font-size:.9rem">Student submits</div>
                        <div class="text-muted" style="font-size:.8rem">Upload a proposal describing your project idea</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="d-flex gap-3 align-items-start">
                    <span class="badge bg-primary rounded-circle p-2" style="font-size:.85rem;min-width:2rem;height:2rem;display:flex;align-items:center;justify-content:center;flex-shrink:0">2</span>
                    <div>
                        <div class="fw-semibold" style="font-size:.9rem">Supervisor browses</div>
                        <div class="text-muted" style="font-size:.8rem">Anonymised proposals shown — no student names visible</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="d-flex gap-3 align-items-start">
                    <span class="badge bg-primary rounded-circle p-2" style="font-size:.85rem;min-width:2rem;height:2rem;display:flex;align-items:center;justify-content:center;flex-shrink:0">3</span>
                    <div>
                        <div class="fw-semibold" style="font-size:.9rem">Interest confirmed</div>
                        <div class="text-muted" style="font-size:.8rem">Supervisor confirms — identities revealed to both parties</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="d-flex gap-3 align-items-start">
                    <span class="badge bg-primary rounded-circle p-2" style="font-size:.85rem;min-width:2rem;height:2rem;display:flex;align-items:center;justify-content:center;flex-shrink:0">4</span>
                    <div>
                        <div class="fw-semibold" style="font-size:.9rem">Module Leader approves</div>
                        <div class="text-muted" style="font-size:.8rem">Final sign-off confirms the allocation</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
