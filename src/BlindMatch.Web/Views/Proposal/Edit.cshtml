@model BlindMatch.Web.ViewModels.Proposal.EditProposalViewModel

@{
	ViewData["Title"] = "Edit Proposal";
}

<h2>Edit Proposal</h2>

<form asp-action="Edit" method="post">
	<input asp-for="Id" type="hidden" />
	<div asp-validation-summary="ModelOnly" class="text-danger"></div>

	<div class="mb-3">
		<label asp-for="Title" class="form-label"></label>
		<input asp-for="Title" class="form-control" />
		<span asp-validation-for="Title" class="text-danger"></span>
	</div>

	<div class="mb-3">
		<label asp-for="Abstract" class="form-label"></label>
		<textarea asp-for="Abstract" class="form-control" rows="6"></textarea>
		<span asp-validation-for="Abstract" class="text-danger"></span>
	</div>

	<div class="mb-3">
		<label asp-for="TechnicalStack" class="form-label"></label>
		<input asp-for="TechnicalStack" class="form-control" />
		<span asp-validation-for="TechnicalStack" class="text-danger"></span>
	</div>

	<div class="mb-3">
		<label asp-for="Keywords" class="form-label"></label>
		<input asp-for="Keywords" class="form-control" />
		<span asp-validation-for="Keywords" class="text-danger"></span>
	</div>

	<div class="mb-3">
		<label asp-for="ResearchAreaId" class="form-label"></label>
		<select asp-for="ResearchAreaId" asp-items="Model.ResearchAreas" class="form-select">
			<option value="">-- Select research area --</option>
		</select>
		<span asp-validation-for="ResearchAreaId" class="text-danger"></span>
	</div>

	<button type="submit" class="btn btn-primary">Save Changes</button>
	<a asp-action="Details" class="btn btn-outline-secondary">Cancel</a>
</form>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}
