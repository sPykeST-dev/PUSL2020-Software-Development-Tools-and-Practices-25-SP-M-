@using BlindMatch.Core.Common
@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BlindMatch</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">BlindMatch</a>

        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                @if (isAuthenticated && User.IsInRole(Roles.Student))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Proposal" asp-action="Index">My Proposal</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Proposal" asp-action="Status">My Status</a>
                    </li>
                }

                @if (isAuthenticated && User.IsInRole(Roles.Supervisor))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Proposal" asp-action="Browse">Browse Projects</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Interest" asp-action="MyInterests">My Interests</a>
                    </li>
                }

                @if (isAuthenticated && User.IsInRole(Roles.ModuleLeader))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="ResearchArea" asp-action="Index">Research Areas</a>
                    </li>
                }

                @if (isAuthenticated && User.IsInRole(Roles.SystemAdministrator))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="UserManagement" asp-action="Index">User Management</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="AuditLog" asp-action="Index">Audit Log</a>
                    </li>
                }

            </ul>

            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                @if (isAuthenticated)
                {
                    <li class="nav-item">
                        <span class="nav-link text-light opacity-75 small">
                            @User.Identity!.Name
                        </span>
                    </li>
                    <li class="nav-item">
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-light my-1">
                                Sign out
                            </button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">Sign in</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="container py-4">

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @success
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @error
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @RenderBody()

</main>

<footer class="border-top text-muted small py-3 mt-auto">
    <div class="container text-center">
        BlindMatch PAS &copy; @DateTime.Now.Year
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
