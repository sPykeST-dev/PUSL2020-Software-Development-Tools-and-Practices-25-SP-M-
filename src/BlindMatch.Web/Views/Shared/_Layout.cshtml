@using BlindMatch.Core.Common
@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var displayName = "";
    var roleLabel   = "";
    if (isAuthenticated)
    {
        displayName = User.FindFirst(AppClaimTypes.FullName)?.Value ?? User.Identity?.Name ?? "";
        roleLabel   = User.IsInRole(Roles.Student)            ? "Student"
                    : User.IsInRole(Roles.Supervisor)          ? "Supervisor"
                    : User.IsInRole(Roles.ModuleLeader)        ? "Module Leader"
                    : User.IsInRole(Roles.SystemAdministrator) ? "Administrator"
                    : "";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BlindMatch</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">BlindMatch</a>

        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                @if (isAuthenticated && User.IsInRole(Roles.Student))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Proposal" asp-action="Details">My Proposal</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Match" asp-action="MyMatch">My Match</a>
                    </li>
                }

                @if (isAuthenticated && User.IsInRole(Roles.Supervisor))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="SupervisorBrowse" asp-action="Index">Browse Projects</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Interest" asp-action="MyInterests">My Interests</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Match" asp-action="MySupervisedMatches">My Matches</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Supervisor" asp-action="Profile">My Profile</a>
                    </li>
                }

                @if (isAuthenticated && User.IsInRole(Roles.ModuleLeader))
                {
                    <li class="nav-item">
                        <a class="nav-link" href="/module-leader/dashboard">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/module-leader/matches">Matches</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/module-leader/proposal-oversight">Proposals</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/module-leader/research-areas">Research Areas</a>
                    </li>
                }

                @if (isAuthenticated && User.IsInRole(Roles.SystemAdministrator))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="UserManagement" asp-action="Index">Users</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/audit-log">Audit Log</a>
                    </li>
                }

            </ul>

            <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center">
                @if (isAuthenticated)
                {
                    <li class="nav-item d-flex align-items-center">
                        <div class="navbar-vsep"></div>
                        <div class="navbar-user">
                            <span class="navbar-user-name">@displayName</span>
                            @if (!string.IsNullOrEmpty(roleLabel))
                            {
                                <span class="navbar-user-role">@roleLabel</span>
                            }
                        </div>
                    </li>
                    <li class="nav-item">
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="nav-link btn btn-link signout-btn">
                                Sign out
                            </button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">Sign in</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="container py-4">

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @success
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @error
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @RenderBody()

</main>


<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
