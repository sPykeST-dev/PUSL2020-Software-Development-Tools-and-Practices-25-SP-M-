@{
    ViewData["Title"] = "Check your email";
}

<div class="row justify-content-center">
    <div class="col-md-5 text-center py-5">

        <h1 class="h4 mb-3">Check your email</h1>
        <p class="text-muted">
            If an account exists for that address, a password reset link has been sent.
            Please check your inbox and follow the link.
        </p>

        <a asp-action="Login" asp-controller="Account" class="btn btn-outline-primary mt-3">
            Back to sign in
        </a>

    </div>
</div>