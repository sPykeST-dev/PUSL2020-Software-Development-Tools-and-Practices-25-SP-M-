@{
    ViewData["Title"] = "Password reset";
}

<div class="row justify-content-center">
    <div class="col-md-5 text-center py-5">

        <h1 class="h4 mb-3">Password reset successful</h1>
        <p class="text-muted">
            Your password has been updated. You can now sign in with your new password.
        </p>

        <a asp-action="Login" asp-controller="Account" class="btn btn-primary mt-3">
            Sign in
        </a>

    </div>
</div>