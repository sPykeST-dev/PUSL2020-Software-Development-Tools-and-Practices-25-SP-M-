@model BlindMatch.Web.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot password";
}

<div class="row justify-content-center">
    <div class="col-md-5">

        <h1 class="h4 mb-2">Reset your password</h1>
        <p class="text-muted small mb-4">
            Enter your email address and we will send you a reset link.
        </p>

        <form asp-action="ForgotPassword" asp-controller="Account" method="post">

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Send reset link</button>

        </form>

        <p class="mt-3 small">
            <a asp-action="Login" asp-controller="Account">Back to sign in</a>
        </p>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}