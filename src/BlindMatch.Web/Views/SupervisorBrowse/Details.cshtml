@model AnonymisedProposalDetailViewModel
@{
    ViewData["Title"] = Model.ProjectCode;
}

<div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
        <h1>@Model.ProjectCode</h1>
        <p>Anonymous proposal detail</p>
    </div>
    <a asp-controller="SupervisorBrowse" asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Browse</a>
</div>


<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">Project Details</div>
            <div class="card-body p-4">
                <div class="mb-4">
                    <div class="text-muted" style="font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em">Title</div>
                    <div class="fw-semibold mt-1" style="font-size:1.1rem">@Model.Title</div>
                </div>
                <div class="mb-4">
                    <div class="text-muted" style="font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em">Abstract</div>
                    <p class="mt-1 mb-0" style="line-height:1.7">@Model.Abstract</p>
                </div>
                <div class="mb-4">
                    <div class="text-muted" style="font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em">Technical Stack</div>
                    <p class="mt-1 mb-0">@Model.TechnicalStack</p>
                </div>
                <div class="mb-0">
                    <div class="text-muted" style="font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em">Keywords</div>
                    <div class="mt-1 d-flex flex-wrap gap-1">
                        @foreach (var kw in (Model.Keywords ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                        {
                            <span class="badge bg-light text-dark border">@kw</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 d-flex flex-column gap-4">
        <div class="card">
            <div class="card-header">Classification</div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted fw-normal">Research Area</dt>
                    <dd class="col-7 fw-semibold">@Model.ResearchArea</dd>

                    <dt class="col-5 text-muted fw-normal mb-0">Submitted</dt>
                    <dd class="col-7 mb-0">@Model.SubmittedAt.ToString("d MMM yyyy")</dd>
                </dl>
            </div>
        </div>

        <div class="card">
            <div class="card-body p-3">
                @if (Model.CanExpressInterest)
                {
                    <p class="text-muted small mb-3">Confirm your interest in supervising this project. You can confirm later from My Interests.</p>
                    <form method="post" asp-controller="Interest" asp-action="ExpressInterest">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="proposalId" value="@Model.Id" />
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-sm">Express Interest</button>
                        </div>
                    </form>
                }
                else
                {
                    <p class="text-muted small mb-3">You have already expressed interest in this project.</p>
                    <div class="d-grid">
                        <a asp-controller="Interest" asp-action="MyInterests" class="btn btn-outline-primary btn-sm">View My Interests</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
