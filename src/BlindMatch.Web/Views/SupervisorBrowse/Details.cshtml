@model AnonymisedProposalDetailViewModel

@{
    ViewData["Title"] = "Proposal Details";
}

<h1>@Model.ProjectCode</h1>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@Model.Title</h5>

        <div class="row">
            <div class="col-md-8">
                <h6>Abstract</h6>
                <p>@Model.Abstract</p>

                <h6>Technical Stack</h6>
                <p>@Model.TechnicalStack</p>

                <h6>Keywords</h6>
                <p>@Model.Keywords</p>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h6>Research Area</h6>
                        <p>@Model.ResearchArea</p>

                        <h6>Submitted</h6>
                        <p>@Model.SubmittedAt.ToString("d")</p>

                        @if (Model.CanExpressInterest)
                        {
                            <form method="post" action="@Url.Action("ExpressInterest", "Interest")">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="proposalId" value="@Model.Id" />
                                <button type="submit" class="btn btn-success btn-lg w-100">
                                    Express Interest
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-lg w-100" disabled>
                                Interest Already Expressed
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a href="@Url.Action("Index", "SupervisorBrowse")" class="btn btn-secondary">Back to Browse</a>
</div>
