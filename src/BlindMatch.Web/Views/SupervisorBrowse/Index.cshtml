@model BrowseViewModel

@{
    ViewData["Title"] = "Browse Proposals";
}

<h1>Browse Proposals</h1>

<form method="get" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <label for="researchAreaId" class="form-label">Filter by Research Area</label>
            <select name="researchAreaId" id="researchAreaId" class="form-select" onchange="this.form.submit()">
                <option value="">All Research Areas</option>
                @foreach (var area in Model.Filter.ResearchAreas)
                {
                    <option value="@area.Value" selected="@area.Selected">@area.Text</option>
                }
            </select>
        </div>
    </div>
</form>

@if (!Model.Proposals.Any())
{
    <div class="alert alert-info">
        No proposals available at the moment.
    </div>
}
else
{
    <div class="row">
        @foreach (var proposal in Model.Proposals)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@proposal.ProjectCode</h5>
                        <p class="card-text">
                            <strong>Research Area:</strong> @proposal.ResearchArea<br>
                            <strong>Keywords:</strong> @proposal.Keywords<br>
                            <strong>Submitted:</strong> @proposal.SubmittedAt.ToString("d")
                        </p>
                    </div>
                    <div class="card-footer">
                        <a href="@Url.Action("Details", new { id = proposal.Id })" class="btn btn-primary">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.Pagination.TotalPages > 1)
    {
        <nav aria-label="Proposal pagination">
            <ul class="pagination justify-content-center">
                @if (Model.Pagination.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { page = Model.Pagination.CurrentPage - 1, researchAreaId = Model.Filter.ResearchAreaId })">Previous</a>
                    </li>
                }

                @for (int i = Math.Max(1, Model.Pagination.CurrentPage - 2); i <= Math.Min(Model.Pagination.TotalPages, Model.Pagination.CurrentPage + 2); i++)
                {
                    <li class="page-item @(i == Model.Pagination.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { page = i, researchAreaId = Model.Filter.ResearchAreaId })">@i</a>
                    </li>
                }

                @if (Model.Pagination.CurrentPage < Model.Pagination.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { page = Model.Pagination.CurrentPage + 1, researchAreaId = Model.Filter.ResearchAreaId })">Next</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
