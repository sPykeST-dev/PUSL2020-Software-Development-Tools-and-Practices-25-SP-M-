@model IEnumerable<BlindMatch.Web.ViewModels.Match.SupervisedMatchItemViewModel>
@using BlindMatch.Core.Enums
@{
    ViewData["Title"] = "My Supervised Projects";
    var list = Model.ToList();
    var count = list.Count;
}

<div class="page-header d-flex align-items-end justify-content-between flex-wrap gap-2">
    <div>
        <h1>My Supervised Projects</h1>
        <p>@count project@(count == 1 ? "" : "s") matched to you</p>
    </div>
</div>

@if (!list.Any())
{
    <div class="card" style="max-width:480px">
        <div class="card-body p-4 text-center">
            <p style="color:var(--text-muted);margin:0;font-size:.875rem">You have no matches yet.</p>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in list)
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center gap-2">
                        <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:.875rem">@item.ProposalTitle</span>
                        @{
                            var bs = item.MatchStatus switch
                            {
                                MatchStatus.Pending  => "background:rgba(180,140,40,.15);color:#d4aa5a;border:1px solid rgba(180,140,40,.3)",
                                MatchStatus.Approved => "background:rgba(74,124,89,.15);color:#6aaa7a;border:1px solid rgba(74,124,89,.3)",
                                MatchStatus.Rejected => "background:rgba(122,48,48,.15);color:#e07878;border:1px solid rgba(122,48,48,.3)",
                                _                    => "background:var(--surface-3);color:var(--text-muted);border:1px solid var(--border-light)"
                            };
                            var sl = item.MatchStatus.ToString();
                        }
                        <span class="badge flex-shrink-0" style="@bs;font-size:.65rem;letter-spacing:.06em">@sl</span>
                    </div>
                    <div class="card-body p-4">
                        @if (item.MatchStatus == MatchStatus.Pending)
                        {
                            <p style="font-size:.8rem;color:var(--text-muted);margin:0">
                                This match is awaiting Module Leader approval. Student details will be available once approved.
                            </p>
                        }
                        else if (item.MatchStatus == MatchStatus.Approved)
                        {
                            <dl class="row mb-0 small" style="row-gap:.25rem">
                                <dt class="col-sm-4" style="color:var(--text-muted);font-weight:500">Student</dt>
                                <dd class="col-sm-8" style="color:var(--text);font-weight:600">@item.StudentFullName</dd>

                                <dt class="col-sm-4" style="color:var(--text-muted);font-weight:500">Email</dt>
                                <dd class="col-sm-8">
                                    <a href="mailto:@item.StudentEmail" style="color:var(--accent)">@item.StudentEmail</a>
                                </dd>

                                @if (item.Programme != null)
                                {
                                    <dt class="col-sm-4" style="color:var(--text-muted);font-weight:500">Programme</dt>
                                    <dd class="col-sm-8" style="color:var(--text)">@item.Programme</dd>
                                }

                                @if (item.YearOfStudy.HasValue)
                                {
                                    <dt class="col-sm-4" style="color:var(--text-muted);font-weight:500">Year</dt>
                                    <dd class="col-sm-8" style="color:var(--text)">Year @item.YearOfStudy</dd>
                                }
                            </dl>
                        }
                        else if (item.MatchStatus == MatchStatus.Rejected)
                        {
                            <p style="font-size:.8rem;color:var(--text-muted);margin:0">
                                This match was rejected by the Module Leader. The proposal has been returned to the pool.
                            </p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
