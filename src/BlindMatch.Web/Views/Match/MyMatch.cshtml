@model BlindMatch.Web.ViewModels.Match.MyMatchViewModel
@using BlindMatch.Core.Enums
@{
    ViewData["Title"] = "My Match";
}

<div class="page-header">
    <h1>Your Project Match</h1>
    <p>Your proposal has been matched with a supervisor</p>
</div>

@if (Model.MatchStatus == MatchStatus.Pending)
{
    <div class="card mb-4" style="border-color:rgba(180,140,40,.3);background:rgba(180,140,40,.06)">
        <div class="card-body p-4">
            <div class="d-flex gap-3 align-items-start">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d4aa5a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:.1rem">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <div>
                    <div style="font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#d4aa5a;margin-bottom:.3rem">Awaiting Approval</div>
                    <p style="font-size:.875rem;color:var(--text-muted);margin:0">
                        A supervisor has been matched to your proposal and is awaiting Module Leader approval. Supervisor details will be revealed once the match is approved.
                    </p>
                </div>
            </div>
        </div>
    </div>
}
else if (Model.MatchStatus == MatchStatus.Approved)
{
    <div class="card mb-4" style="border-color:rgba(74,124,89,.3);background:rgba(74,124,89,.06)">
        <div class="card-body p-4">
            <div class="d-flex gap-3 align-items-start">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6aaa7a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:.1rem">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <div>
                    <div style="font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#6aaa7a;margin-bottom:.3rem">Match Confirmed</div>
                    <p style="font-size:.875rem;color:var(--text-muted);margin:0">
                        Your match has been approved. Your supervisor's contact details are shown below — reach out to arrange your first meeting.
                    </p>
                </div>
            </div>
        </div>
    </div>
}
else if (Model.MatchStatus == MatchStatus.Rejected)
{
    <div class="card mb-4" style="border-color:rgba(122,48,48,.3);background:rgba(122,48,48,.06)">
        <div class="card-body p-4">
            <div class="d-flex gap-3 align-items-start">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e07878" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:.1rem">
                    <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
                <div>
                    <div style="font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#e07878;margin-bottom:.3rem">Match Rejected</div>
                    <p style="font-size:.875rem;color:var(--text-muted);margin:0">
                        This match was rejected by the Module Leader. Your proposal has been returned to the pool and may be matched again.
                    </p>
                </div>
            </div>
        </div>
    </div>
}

<div class="row g-4">
    @if (Model.MatchStatus == MatchStatus.Approved)
    {
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">Supervisor Details</div>
                <div class="card-body p-4">
                    <dl class="row mb-0 small" style="row-gap:.25rem">
                        <dt class="col-4" style="color:var(--text-muted);font-weight:500">Name</dt>
                        <dd class="col-8" style="color:var(--text);font-weight:600">@Model.SupervisorFullName</dd>

                        <dt class="col-4" style="color:var(--text-muted);font-weight:500">Email</dt>
                        <dd class="col-8">
                            <a href="mailto:@Model.SupervisorEmail" style="color:var(--accent)">@Model.SupervisorEmail</a>
                        </dd>

                        <dt class="col-4" style="color:var(--text-muted);font-weight:500">Department</dt>
                        <dd class="col-8" style="color:var(--text)">@Model.SupervisorDepartment</dd>
                    </dl>
                </div>
            </div>
        </div>
    }

    <div class="@(Model.MatchStatus == MatchStatus.Approved ? "col-md-6" : "col-12")">
        <div class="card h-100">
            <div class="card-body p-4 d-flex flex-column align-items-center justify-content-center text-center">
                <div style="font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-subtle);margin-bottom:.75rem">Match Status</div>
                @{
                    var (badgeStyle, statusLabel, statusDesc) = Model.MatchStatus switch
                    {
                        MatchStatus.Pending  => (
                            "background:rgba(180,140,40,.15);color:#d4aa5a;border:1px solid rgba(180,140,40,.3)",
                            "Pending",
                            "Awaiting Module Leader approval."),
                        MatchStatus.Approved => (
                            "background:rgba(74,124,89,.15);color:#6aaa7a;border:1px solid rgba(74,124,89,.3)",
                            "Approved",
                            "This match has been approved by the Module Leader."),
                        MatchStatus.Rejected => (
                            "background:rgba(122,48,48,.15);color:#e07878;border:1px solid rgba(122,48,48,.3)",
                            "Rejected",
                            "This match was rejected. Your proposal is back in the pool."),
                        _ => (
                            "background:var(--surface-3);color:var(--text-muted);border:1px solid var(--border-light)",
                            Model.MatchStatus.ToString(),
                            "")
                    };
                }
                <span class="badge" style="@badgeStyle;font-size:.75rem;letter-spacing:.06em;padding:.45rem 1rem">@statusLabel</span>
                @if (!string.IsNullOrEmpty(statusDesc))
                {
                    <p style="color:var(--text-muted);font-size:.8rem;margin-top:.75rem;margin-bottom:0">@statusDesc</p>
                }
            </div>
        </div>
    </div>
</div>
