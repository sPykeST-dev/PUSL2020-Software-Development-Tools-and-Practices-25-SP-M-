@{
    ViewData["Title"] = "No Match Yet";
}

<div class="page-header">
    <h1>No Match Yet</h1>
    <p>Your proposal hasn't been matched with a supervisor yet</p>
</div>

<div class="card" style="max-width:480px">
    <div class="card-body p-4 text-center">
        <p style="color:var(--text-muted);font-size:.875rem;margin-bottom:1.25rem">
            Supervisors are still browsing proposals. Your supervisor details will be shown here once a supervisor confirms interest and the Module Leader approves the match.
        </p>
        <a asp-controller="Proposal" asp-action="Details" class="btn btn-outline-secondary btn-sm">Back to My Proposal</a>
    </div>
</div>
