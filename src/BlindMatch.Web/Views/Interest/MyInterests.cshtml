@model List<MyInterestItemViewModel>
@{
    ViewData["Title"] = "My Interests";
    var count = Model.Count;
}

<div class="page-header d-flex align-items-end justify-content-between flex-wrap gap-2">
    <div>
        <h1>My Interests</h1>
        <p>@count proposal@(count == 1 ? "" : "s") you've expressed interest in</p>
    </div>
    <a href="@Url.Action("Index", "SupervisorBrowse")" class="btn btn-outline-secondary btn-sm mb-1">Browse proposals</a>
</div>

@if (!Model.Any())
{
    <div class="card" style="max-width:480px">
        <div class="card-body p-4 text-center">
            <p style="color:var(--text-muted);margin:0;font-size:.875rem">
                You haven't expressed interest in any proposals yet.
            </p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Project Code</th>
                        <th>Title</th>
                        <th>Research Area</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var interest in Model)
                    {
                        <tr>
                            <td style="white-space:nowrap;color:var(--text-muted);font-size:.8rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase">
                                @interest.ProjectCode
                            </td>
                            <td style="max-width:320px">
                                <span style="display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:.875rem">
                                    @interest.Title
                                </span>
                            </td>
                            <td>
                                <span class="badge browse-area-badge">@interest.ResearchArea</span>
                            </td>
                            <td>
                                @if (interest.Status == BlindMatch.Core.Enums.InterestStatus.Pending)
                                {
                                    <span class="badge" style="background:rgba(180,140,40,.15);color:#d4aa5a;border:1px solid rgba(180,140,40,.25);font-size:.65rem;letter-spacing:.06em">Pending</span>
                                }
                                else
                                {
                                    <span class="badge" style="background:rgba(74,124,89,.15);color:#6aaa7a;border:1px solid rgba(74,124,89,.25);font-size:.65rem;letter-spacing:.06em">Confirmed</span>
                                }
                            </td>
                            <td style="white-space:nowrap;color:var(--text-muted);font-size:.85rem">
                                @interest.CreatedAt.ToString("d MMM yyyy")
                            </td>
                            <td>
                                @if (interest.CanConfirm)
                                {
                                    <a href="@Url.Action("ConfirmInterest", new { id = interest.Id })" class="btn btn-primary btn-sm">
                                        Confirm Interest
                                    </a>
                                }
                                else
                                {
                                    <span style="font-size:.78rem;color:var(--text-muted)">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
