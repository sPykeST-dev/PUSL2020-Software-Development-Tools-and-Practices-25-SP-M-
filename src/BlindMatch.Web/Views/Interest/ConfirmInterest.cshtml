@model ConfirmInterestViewModel

@{
    ViewData["Title"] = "Confirm Interest";
}

<div class="page-header d-flex align-items-end justify-content-between flex-wrap gap-2">
    <div>
        <h1>Confirm Interest</h1>
        <p>Review the details below before proceeding</p>
    </div>
    <a href="@Url.Action("MyInterests")" class="btn btn-outline-secondary btn-sm mb-1">Back to My Interests</a>
</div>

<div class="row g-4 mx-auto" style="max-width:720px">

    <div class="col-12">
        <div class="card" style="border-color:rgba(180,140,40,.3);background:rgba(180,140,40,.06)">
            <div class="card-body p-4">
                <div class="d-flex gap-3 align-items-start">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d4aa5a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:.15rem">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                        <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                    <div>
                        <div style="font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#d4aa5a;margin-bottom:.35rem">Before You Confirm</div>
                        <p style="font-size:.875rem;color:var(--text-muted);margin:0">
                            Confirming your interest creates a pending match that the Module Leader must approve. Your identity and the student's identity are only revealed to each other <strong style="color:var(--text)">after the Module Leader approves the match.</strong>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card">
            <div class="card-header">Proposal</div>
            <div class="card-body p-4">
                <div class="mb-1" style="font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--text-muted)">@Model.ProjectCode</div>
                <div style="font-size:1rem;font-weight:600;color:var(--text);margin-bottom:1.25rem">@Model.Title</div>

                <div style="font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-subtle);margin-bottom:.75rem">Your information — revealed to the student upon approval</div>

                <dl class="row mb-0 small" style="row-gap:.25rem">
                    <dt class="col-4" style="color:var(--text-muted);font-weight:500">Name</dt>
                    <dd class="col-8" style="color:var(--text)">@Model.SupervisorName</dd>

                    <dt class="col-4" style="color:var(--text-muted);font-weight:500">Email</dt>
                    <dd class="col-8" style="color:var(--text)">@Model.SupervisorEmail</dd>

                    <dt class="col-4" style="color:var(--text-muted);font-weight:500">Department</dt>
                    <dd class="col-8" style="color:var(--text)">@Model.SupervisorDepartment</dd>
                </dl>

                <div class="mt-3 pt-3" style="border-top:1px solid var(--border);font-size:.8rem;color:var(--text-muted)">
                    The student's identity will be revealed to you once the Module Leader approves the match.
                </div>
            </div>
            <div class="card-footer px-4 py-3">
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="InterestId" value="@Model.InterestId" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm">Confirm Interest</button>
                        <a href="@Url.Action("MyInterests")" class="btn btn-outline-secondary btn-sm">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

</div>
